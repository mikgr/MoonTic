@page
@model LogInModel
@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card bg-light" style="box-shadow: 2px 4px 12px 2px rgba(0,0,0,0.4);">
            <div class="card-body p-4">
                <h2 class="text-center text-dark disp mb-4">Log in</h2>
                <form method="post" id="loginForm">
                    <div class="mb-3">
                        <input type="text" class="form-control" name="username" placeholder="Username" required />
                    </div>
                    <div class="mb-3">
                        <input type="password" class="form-control" name="password" placeholder="Password" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Log in</button>
                </form>
                <div class="text-center my-3 text-dark">———————————— or ————————————</div>
                <button class="btn btn-dark w-100 mb-2">🍎 Fake Sign in with Apple</button>
                <button class="btn btn-danger w-100">🇬 Fake Sign in with Google</button>
            </div>
        </div>
    </div>
</div>
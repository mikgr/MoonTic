@using SpikeDb
@using Ticketer.Model
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>~ @ViewData["Title"] | Ticketer ~</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Gravitas+One&display=swap" rel="stylesheet">
    <script src="js/finisher-header.es5.min.js" type="text/javascript"></script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" integrity="sha384-/TgkGk7p307TH7EXJDuUlgG3Ce1UVolAOFopFekQkkXihi5u/6OCvVKyz1W+idaz" crossorigin="anonymous"></script>
</head>
<body>

<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3" data-bs-theme='dark'>
            <div class="container">
            <a class="navbar-brand display-2" asp-area="" asp-page="/Events">Moontic</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-light fw-bolder" asp-area="" asp-page="/Events">🗓️ Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light fw-bolder" asp-area="" asp-page="/Tickets">🎟 Tickets</a>
                    </li>
                </ul>
                <div class="float-end">
                    <lu class="navbar-nav">
                        <a class="nav-link text-white" style="margin-right: 1rem; color:#b6b6b6 !important;" href="/Explorer/Contracts">
                            🌐 Explorer
                        </a>
                        <a class="btn text-white" style="background-color: #35383A; margin-right: 1rem;" href="/EventOrganizer">
                            Event Organizer
                        </a>
                        @if (GetLoggedInUserName() == "")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-bolder float-end" asp-area="" asp-page="/LogIn">LogIn</a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <div class="nav-item dropdown d-flex align-items-center">
                                    <a href="#" class="nav-link text-white text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                                        <strong>👤 @GetLoggedInUserName()</strong>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-light text-small shadow" aria-labelledby="dropdownUser1" style="">
                                        <li><a class="dropdown-item" href="/Profile">Profile</a></li>
                                        <li>
                                            <form method="post" asp-page="/Profile" asp-page-handler="LogOut">
                                                <button type="submit" class="dropdown-item">Sign out</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </li>
                        }
                    </lu>
                </div>
            </div>
        </div>
    </nav>
</header>
<div class="header finisher-header" style="width: 100%; height: 100%; position: fixed; top: 0; left: 0; z-index: -1;">
</div>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

@* <footer class="border-top footer text-muted"> *@
@*     <div class="container"> *@
@*         &copy; 2026 - Ticketer.Cli - <a asp-area="" asp-page="/Privacy">Privacy</a> *@
@*     </div> *@
@* </footer> *@

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
<script type="text/javascript">
new FinisherHeader({
  "count": 37,
  "size": {
    "min": 838,
    "max": 1067,
    "pulse": 0.3
  },
  "speed": {
    "x": {
      "min": 0.1,
      "max": 0.4
    },
    "y": {
      "min": 0.3,
      "max": 0.7
    }
  },
  "colors": {
    "background": "#3e3e3e",
    "particles": [
      "#ffffff",
      "#fff25b",
      "#ffb000"
    ]
  },
  "blending": "none",
  "opacity": {
    "center": 1,
    "edge": 0.05
  },
  "skew": 0,
  "shapes": [
    "c"
  ]
});
</script>

<!-- Container for dynamically injected modals -->
<div id="modal-container"></div>

<script>
    // Generic HTMX modal handler
    document.body.addEventListener('htmx:afterSwap', function(evt) {
        // Only act if content was injected into modal-container
        if (evt.detail.target.id !== 'modal-container') return;

        const modalEl = evt.detail.target.querySelector('.modal');
        if (!modalEl) return;

        // Initialize and show the modal
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();

        // Optional: remove modal from DOM after closing to prevent duplicates
        modalEl.addEventListener('hidden.bs.modal', () => {
            modalEl.remove();
        });
    });

    // Fade out and remove card when transfer completes (HX-Trigger: fadeOutCard)
    document.body.addEventListener('fadeOutCard', function(evt) {
        var eventId = evt.detail.eventId;
        var ticketId = evt.detail.ticketId;
        var el = document.getElementById('card_' + eventId + '_' + ticketId);
        if (el) {
            el.classList.add('card-fade-out');
            el.addEventListener('transitionend', function() { el.remove(); }, { once: true });
        }
    });
</script>
</body>
</html>

@{
    string GetLoggedInUserName()
    {
        return HttpContextAccessor.HttpContext?.Session.GetString("UserName") ?? "";
    }
}

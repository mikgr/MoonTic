@model TicketActionStatus

<form class="d-inline"
      hx-post="/Tickets?handler=Transfer"
      hx-target="@($"#status_{Model.ContractAddress}_{Model.TicketId}")"
      hx-swap="innerHTML">
<div class="modal fade" tabindex="-1" aria-labelledby="transferModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="transferModalLabel">Transfer Ticket No. @Model.TicketId</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Transfer this ticket to another user. Once transferred, you will no longer own this ticket.</p>
                <div class="mb-3">
                    <label for="recipient-address" class="form-label">Recipient Address</label>
                    <input type="text" class="form-control" id="recipient-address" name="recipientAddress" placeholder="Enter address 0x..." />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                @Html.AntiForgeryToken()
                <input type="hidden" name="contractAddress" value="@Model.ContractAddress" />
                <input type="hidden" name="ticketId" value="@Model.TicketId" />
                <button type="submit" class="btn btn-primary">Transfer</button>
            </div>
        </div>
    </div>
</div>
</form>
